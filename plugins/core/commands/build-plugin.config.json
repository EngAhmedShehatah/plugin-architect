{
  "command": "build-plugin",
  "questionFlow": [
    {
      "step": 2,
      "action": "parallel-scan",
      "agents": [
        { "name": "git-detector", "path": "../agents/git-detector.md" },
        { "name": "schema-scanner", "path": "../agents/schema-scanner.md" },
        { "name": "tech-stack-detector", "path": "../agents/tech-stack-detector.md" }
      ]
    },
    {
      "step": 3,
      "condition": "schema-scanner.isMonorepo === true",
      "questions": [
        {
          "id": "monorepo-strategy",
          "prompt": "This is a monorepo project. Do you want one plugin for all packages, or one separate plugin for each?",
          "options": ["one-for-all", "one-per-package"]
        },
        {
          "id": "shared-plugin",
          "condition": "monorepo-strategy === 'one-per-package'",
          "prompt": "Do you want a shared/core plugin to avoid duplication across packages?",
          "options": ["yes-shared-core", "no-duplication-is-fine"]
        }
      ]
    },
    {
      "step": 3,
      "action": "output-folder-structure",
      "note": "Output partial folder structure (levels 1-3 only) and wait for user confirmation before proceeding to mode selection"
    },
    {
      "step": 4,
      "id": "mode-selection",
      "prompt": "Which mode do you want to build your plugin with?",
      "options": [
        { "value": "light", "descriptionSource": "../modes/light.md" },
        { "value": "medium", "descriptionSource": "../modes/medium.md" },
        { "value": "deep", "descriptionSource": "../modes/deep.md" }
      ],
      "action": "output-full-folder-structure",
      "note": "After mode selection, output complete folder structure including validation, pre-commit, and CI. Wait for confirmation."
    },
    {
      "step": 5,
      "action": "parallel-blueprint-select",
      "agent": "../agents/blueprint-selector.md",
      "note": "Spin one blueprint-selector subagent per confirmed skill-worthy tech in parallel. Each receives only: tech."
    },
    {
      "step": 6,
      "id": "target-platform",
      "prompt": "Which platform do you want this plugin to target?",
      "options": [
        "Claude Code",
        "OpenCode",
        "Codex",
        "Copilot",
        "Cursor",
        "Windsurf",
        "Cline",
        "Continue",
        "Kilo Code",
        "Roo Code",
        "Augment Code",
        "Aider Desk",
        "Amp",
        "Bob",
        "Crush",
        "Devin",
        "Droid",
        "ForgeCode",
        "Goose",
        "iFlow CLI",
        "Kiro CLI",
        "Mistral Vibe",
        "OpenHands",
        "Qwen Code",
        "Atlassian Rovo Dev",
        "Tabnine CLI",
        "Trae",
        "Warp",
        "Replit Agent",
        "JetBrains Junie",
        "Qoder",
        "Google Antigravity",
        "multi-platform"
      ]
    }
  ],
  "defaults": {
    "light": {
      "splitStrategy": "by-role",
      "skillsPerRole": 1,
      "agentsPerRole": 1,
      "namingConvention": "role-based",
      "examples": {
        "implementation": ["implementer"],
        "testing": ["tester"],
        "review": ["code-reviewer"],
        "git": ["git-handler"]
      }
    },
    "medium": {
      "splitStrategy": "by-concern",
      "skillsPerRole": "1-per-concern",
      "agentsPerRole": "1-per-concern",
      "namingConvention": "concern-based",
      "examples": {
        "implementation": ["implementer"],
        "testing": ["unit-tester", "e2e-tester"],
        "review": ["code-reviewer"],
        "git": ["git-handler"]
      }
    },
    "deep": {
      "splitStrategy": "by-domain-and-concern",
      "skillsPerRole": "1-per-domain-concern-pair",
      "agentsPerRole": "1-per-domain-concern-pair",
      "namingConvention": "domain-specific",
      "examples": {
        "implementation": ["core-implementer", "api-implementer", "mcp-implementer"],
        "testing": ["unit-tester", "e2e-tester", "mcp-tester"],
        "review": ["code-reviewer", "security-scanner"],
        "git": ["git-handler"]
      }
    }
  },
  "folderStructureRules": {
    "always": [
      ".claude-plugin/plugin.json",
      "plugins/core/.claude-plugin/plugin.json",
      "plugins/core/skills/",
      "plugins/core/agents/",
      "plugins/core/commands/",
      "plugins/core/references/",
      "plugins/core/scripts/",
      "plugins/core/.mcp.json",
      "README.md"
    ]
  }
}
