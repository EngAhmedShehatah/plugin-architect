{
  "name": "core",
  "version": "1.0.12",
  "description": "A Claude Code plugin that devs can use to create focused custom plugins for their projects",
  "author": {
    "name": "Ahmed Shehatah",
    "email": "engahmedshehatah@gmail.com",
    "url": "https://github.com/EngAhmedShehatah"
  },
  "repository": "https://github.com/EngAhmedShehatah/plugin-architect/plugins/core",
  "license": "MIT",
  "keywords": [
    "Claude Code",
    "Plugin"
  ],
  "skills": [
    "./skills/agent-create",
    "./skills/blueprint-select",
    "./skills/git-detect",
    "./skills/plugin-validate",
    "./skills/schema-scan",
    "./skills/skill-create",
    "./skills/tech-stack-detect"
  ],
  "commands": [
    "./commands/build-plugin.md"
  ],
  "agents": [
    "./agents/git-detector.md",
    "./agents/schema-scanner.md",
    "./agents/tech-stack-detector.md",
    "./agents/plugin-validator.md",
    "./agents/blueprint-selector.md",
    "./agents/skill-creator.md",
    "./agents/agent-creator.md"
  ],
  "mcpServers": "./.mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-init.mjs"
          }
        ]
      }
    ]
  }
}
