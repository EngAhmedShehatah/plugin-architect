{
  "name": "core",
  "version": "1.0.16",
  "description": "A skill-only Claude Code plugin that devs can use to create focused custom plugins for their projects",
  "author": {
    "name": "Ahmed Shehatah",
    "email": "engahmedshehatah@gmail.com",
    "url": "https://github.com/EngAhmedShehatah"
  },
  "repository": "https://github.com/EngAhmedShehatah/plugin-architect/plugins/core",
  "license": "MIT",
  "keywords": [
    "Claude Code",
    "Plugin"
  ],
  "skills": [
    "./skills/blueprint-select",
    "./skills/build-plugin",
    "./skills/git-detect",
    "./skills/plugin-validate",
    "./skills/schema-scan",
    "./skills/skeleton-build",
    "./skills/skill-create",
    "./skills/tech-stack-detect"
  ],
  "mcpServers": "./.mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-init.mjs"
          }
        ]
      }
    ]
  }
}

