{
  "command": "build-plugin",
  "questionFlow": [
    {
      "step": 2,
      "action": "sequential-scan",
      "skills": [
        { "name": "git-detect", "path": "../../skills/git-detect/SKILL.md" },
        { "name": "schema-scan", "path": "../../skills/schema-scan/SKILL.md" },
        { "name": "tech-stack-detect", "path": "../../skills/tech-stack-detect/SKILL.md" }
      ]
    },
    {
      "step": 3,
      "action": "tech-classification",
      "note": "Classify detected technologies into skill-worthy and utility/infra groups, then wait for user confirmation"
    },
    {
      "step": 4,
      "action": "sequential-blueprint-select",
      "skill": "../../skills/blueprint-select/SKILL.md",
      "note": "Run blueprint selection one tech at a time for confirmed skill-worthy technologies"
    },
    {
      "step": 5,
      "id": "mode-selection",
      "prompt": "Which mode do you want to build your plugin with?",
      "options": [
        { "value": "light", "descriptionSource": "../../modes/light.md" },
        { "value": "medium", "descriptionSource": "../../modes/medium.md" },
        { "value": "deep", "descriptionSource": "../../modes/deep.md" }
      ]
    }
  ],
  "folderStructureRules": {
    "always": [
      ".claude-plugin/plugin.json",
      "plugins/core/.claude-plugin/plugin.json",
      "plugins/core/skills/",
      "plugins/core/scripts/session-init.mjs",
      "plugins/core/scripts/version-bump.mjs",
      "plugins/core/scripts/validate-plugins.mjs",
      "plugins/core/scripts/validate-claude-code.mjs",
      "plugins/core/.mcp.json",
      "README.md"
    ]
  }
}
